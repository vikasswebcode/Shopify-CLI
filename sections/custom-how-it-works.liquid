{%- style -%}
  .hiw-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .hiw-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }
{%- endstyle -%}

<section class="hiw-section-{{ section.id }} hiw-section">
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="hiw-heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="hiw-grid hiw-grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div class="hiw-card" {{ block.shopify_attributes }}>

          {%- if block.settings.icon != blank -%}
            <div class="hiw-card__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 96 }}"
                alt="{{ block.settings.title | escape }}"
                width="64"
                height="64"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          <div class="hiw-card__body">
            {%- if block.settings.title != blank -%}
              <p class="hiw-card__title">{{ block.settings.title | escape }}</p>
            {%- endif -%}
            {%- if block.settings.sub_text != blank -%}
              <p class="hiw-card__sub">{{ block.settings.sub_text | escape }}</p>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .hiw-section {
    box-sizing: border-box;
  }

  .hiw-heading {
    text-align: center;
    margin: 0 0 40px;
    font-weight: 600;
  }

  .hiw-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  @media screen and (min-width: 750px) {
    .hiw-grid--1 { grid-template-columns: 1fr; }
    .hiw-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .hiw-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .hiw-grid--4 { grid-template-columns: repeat(4, 1fr); }
    .hiw-grid--5 { grid-template-columns: repeat(5, 1fr); }
    .hiw-grid--6 { grid-template-columns: repeat(6, 1fr); }
  }

  .hiw-card {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 14px;
    padding: 28px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .hiw-card__icon {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .hiw-card__icon img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .hiw-card__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .hiw-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.45;
    color: inherit;
  }

  .hiw-card__sub {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.4;
    color: rgba(0, 0, 0, 0.5);
  }
</style>

{% schema %}
{
  "name": "How It Works",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How it works"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fefde8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Description",
          "default": "Place your order online."
        },
        {
          "type": "text",
          "id": "sub_text",
          "label": "Sub-text (smaller, optional)",
          "info": "Use for a secondary line below the main text."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "How It Works",
      "category": "Custom",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Place your order online."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Receive an email confirmation and your test kit by mail from our lab partner."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Follow the kit instructions and return the sample using the enclosed prepaid shipping label."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Get notified to schedule a 30-minute session",
            "sub_text": "to review your results and explore practitioner-guided next steps."
          }
        }
      ]
    }
  ]
}
{% endschema %}
