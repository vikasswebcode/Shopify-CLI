<style>
  .help-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  .help-section__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    margin-bottom: 48px;
    color: #1a1a1a;
  }

  .help-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .help-card {
    background: #f5f5f5;
    border-radius: 12px;
    padding: 48px 36px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .help-card:hover {
    box-shadow: 0 8px 30px rgba(128, 0, 255, 0.1);
    transform: translateY(-4px);
  }

  .help-card__icon {
    width: 72px;
    height: 72px;
    margin-bottom: 20px;
    color: #7c3aed;
  }

  .help-card__heading {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  .help-card__desc {
    font-size: 15px;
    line-height: 1.6;
    color: #666;
    margin-bottom: 28px;
    max-width: 300px;
  }

  .help-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border: none;
    border-radius: 6px;
    background: linear-gradient(135deg, #9333ea, #c026d3);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: filter 0.25s ease, transform 0.25s ease;
    margin-top: auto;
  }

  .help-card__btn:hover {
    filter: brightness(1.12);
    transform: scale(1.04);
  }

  .help-card__btn-arrow {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    transition: transform 0.25s ease;
  }

  .help-card__btn:hover .help-card__btn-arrow {
    transform: translateX(3px);
  }
</style>

<section class="help-section">
  {% if section.settings.title != blank %}
    <h2 class="help-section__title">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="help-cards">
    {% for block in section.blocks %}
      <div class="help-card" {{ block.shopify_attributes }}>

        {%- comment -%} Icon SVGs {%- endcomment -%}
        {% case block.settings.icon %}
          {% when 'support' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 6C17.64 6 6 16.06 6 28.5c0 7.18 3.98 13.56 10.16 17.72L14 54l10.4-5.2C26.72 49.58 29.32 50 32 50c14.36 0 26-10.06 26-22.5S46.36 6 32 6z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="22" cy="28" r="3" fill="currentColor"/>
              <circle cx="32" cy="28" r="3" fill="currentColor"/>
              <circle cx="42" cy="28" r="3" fill="currentColor"/>
            </svg>
          {% when 'returns' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M40 8L52 18V46c0 2-1.6 4-4 4H16c-2.4 0-4-2-4-4V12c0-2 1.6-4 4-4h24z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 18h16v12H12z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" fill="none"/>
              <path d="M20 18v12" stroke="currentColor" stroke-width="3"/>
              <path d="M12 24h16" stroke="currentColor" stroke-width="3"/>
              <path d="M28 30h16M28 38h16M28 22h8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M40 8v10h12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          {% when 'warranty' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 4L8 16v16c0 14.4 10.24 27.84 24 32 13.76-4.16 24-17.6 24-32V16L32 4z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M22 32l7 7 13-14" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% when 'shipping' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="18" width="38" height="26" rx="3" stroke="currentColor" stroke-width="3"/>
              <path d="M42 26h10l8 10v8H42V26z" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
              <circle cx="16" cy="47" r="5" stroke="currentColor" stroke-width="3"/>
              <circle cx="50" cy="47" r="5" stroke="currentColor" stroke-width="3"/>
              <path d="M8 28h20M8 34h14" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          {% when 'contact' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="12" width="52" height="38" rx="4" stroke="currentColor" stroke-width="3"/>
              <path d="M6 16l26 18L58 16" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% when 'gift' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="26" width="48" height="32" rx="3" stroke="currentColor" stroke-width="3"/>
              <rect x="6" y="16" width="52" height="12" rx="3" stroke="currentColor" stroke-width="3"/>
              <path d="M32 16v42" stroke="currentColor" stroke-width="3"/>
              <path d="M32 16c0 0-8-10 0-10s0 10 0 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M32 16c0 0 8-10 0-10s0 10 0 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          {% when 'star' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 6l6.4 13 14.3 2.1-10.35 10.1 2.44 14.27L32 38.75l-12.79 6.72 2.44-14.27L11.3 21.1l14.3-2.1L32 6z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% when 'phone' %}
            <svg class="help-card__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 6h12l5 14-7 4c3 6 8 11 14 14l4-7 14 5v12c0 3-2.5 5-5.5 4.5C20 50 14 14 14 6z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        {% endcase %}

        <h3 class="help-card__heading">{{ block.settings.heading }}</h3>
        <p class="help-card__desc">{{ block.settings.description }}</p>

        {% if block.settings.button_text != blank %}
          <a href="{{ block.settings.button_link }}" class="help-card__btn">
            {{ block.settings.button_text }}
            <svg class="help-card__btn-arrow" viewBox="0 0 16 16">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
        {% endif %}

      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Help Cards",
  "tag": "section",
  "class": "section-help-cards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "How can we help?"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 96,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Help Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "support",  "label": "Support (Chat Bubble)" },
            { "value": "returns",  "label": "Returns (Document)" },
            { "value": "warranty", "label": "Warranty (Shield)" },
            { "value": "shipping", "label": "Shipping (Truck)" },
            { "value": "contact",  "label": "Contact (Email)" },
            { "value": "gift",     "label": "Gift" },
            { "value": "star",     "label": "Star / Review" },
            { "value": "phone",    "label": "Phone" }
          ],
          "default": "support"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Card Heading",
          "default": "Support"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card Description",
          "default": "Already purchased and have a question about your product? Try our FAQs."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "FAQs"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Help Cards",
      category": "Custom",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "support",
            "heading": "Support",
            "description": "Already purchased and have a question about your product? Try our FAQs.",
            "button_text": "FAQs"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "returns",
            "heading": "Returns",
            "description": "We understand things don't always work out. Visit our returns pages for more.",
            "button_text": "Returns"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "warranty",
            "heading": "Warranty",
            "description": "Just bought your product and want to register the warranty? Visit our page.",
            "button_text": "Register"
          }
        }
      ]
    }
  ]
}
{% endschema %}
