  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Left Title",
      "default": "Top 10 Symptoms\nof Mold\nExposure"
